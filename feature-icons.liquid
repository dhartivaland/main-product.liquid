<div class="product-feature-icons">
  {% for i in (1..3) %}
    {% assign image_key = 'image_' | append: i %}
    {% assign icon_key = 'icon_' | append: i %}
    {% assign heading_key = 'heading_' | append: i %}

    {% assign image = block.settings[image_key] %}
    {% assign icon = block.settings[icon_key] %}
    {% assign heading = block.settings[heading_key] %}

    {% if image != blank or heading != blank %}
      <div class="feature-item">
        {% if image != blank %}
          <div class="feature-icon">
            <img
              src="{{ image | image_url: width: 40 }}"
              srcset="
                {{ image | image_url: width: 40 }} 1x,
                {{ image | image_url: width: 80 }} 2x
              "
              alt="{{ heading | strip_html | escape }}"
              loading="lazy"
              width="40"
              height="{{ 40 | divided_by: image.aspect_ratio | ceil }}"
            >
          </div>

        {% elsif icon != 'none' %}
          {% render 'icon-accordion', icon: icon %}
        {% endif %}

        {% if heading != blank %}
          <div class="feature-text">
            {{ heading }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  {% endfor %}
</div>
