                            <button
                              class="swiper-button-prev swiper-button-prev--{{ block.id }}"
                              type="button"
                              aria-label="Previous"
                              title="Previous"
                            ></button>
                            <div class="center-line"></div>
                            <button
                              class="swiper-button-next swiper-button-next--{{ block.id }}"
                              type="button"
                              aria-label="Next"
                              title="Next"
                            ></button>
                          </div>
                        {% endif %}
                      </div>

                      {%- if recommendations.performed -%}
                        <aside class="product__accordion" {{ block.shopify_attributes }}>
                          <div class="complementary-products__container">
                            <div
                              class="swiper complementary-swiper"
                              data-block-id="{{ block.id }}"
                              data-navigation="{{ block.settings.enable_navigation }}"
                            >
                              <div class="swiper-wrapper">
                                {%- for product in recommendations.products -%}
                                  <div class="swiper-slide">
                                    {% render 'card-product',
                                      card_product: product,
                                      media_aspect_ratio: 'square',
                                      section_id: section.id
                                    %}
                                  </div>
                                {%- endfor -%}
                              </div>
                            </div>
                          </div>
                        </aside>
                      {%- endif -%}
                    </product-recommendations>
                  {%- endif -%}
              {% endcase %}
            {%- endfor -%}

            <a
              {% if product == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ product.url }}"
              {% endif %}
              class="link product__view-details animate-arrow"
            >
              <p>
                {{ 'products.product.view_full_details' | t }}
                {{- 'icon-arrow.svg' | inline_asset_content -}}
              </p>
            </a>
          </div>
        </div>
      </div>

      {% if section.settings.pdp_sticky_bar %}
        {% render 'pdp-sticky-bar' %}
      {% endif %}
    </product-info>

    {% assign popups = section.blocks | where: 'type', 'popup' %}
    {%- for block in popups -%}
      {% assign page_handle = block.settings.page.handle %}

      <modal-dialog
        id="PopupModal-{{ block.id }}"
        class="product-popup-modal popup-{{page_handle }}"
        {{ block.shopify_attributes }}
      >
        <div
          role="dialog"
          aria-label="{{ block.settings.text }}"
          aria-modal="true"
          class="product-popup-modal__content"
          tabindex="-1"
        >
