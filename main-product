<div class="section-{{ section.id }}-padding main-product-{{ section.id }} main-product-section {% if request.page_type == 'product' and request.design_mode == false %}is-not-modal{% endif %}">
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'section-product-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}

  {{ 'bundle-products.css' | asset_url | stylesheet_tag }}

  {{ 'complementary-product.css' | asset_url | stylesheet_tag }}

  {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

  {{ 'gift-card-recipient-form.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}

  {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
  {{ 'swiper-bundle.min.js' | asset_url | script_tag }}

  <script src="{{ 'recommendations.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'share.js' | asset_url }}" defer="defer"></script>

  <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>

  <script src="{{ 'product-slider.js' | asset_url }}" defer="defer"></script>

  {% style %}
    .section-{{ section.id }}-padding {
           padding-top: {{ section.settings.padding_top_mobile }}px;
        padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      }

      {% for block in section.blocks %}
       {%- case block.type -%}
       {%- when '@app' -%}
         {% render block %}
        {% when 'divider' %}
      .divider--{{ block.id }}.custom-divider-wrapper{
         max-width: {{ block.settings.custom_width }}%;
         margin-top: {{ block.settings.margin_top }}px;
         margin-bottom: {{ block.settings.margin_bottom }}px;
      }
    .divider--{{ block.id }} .custom-divider-line{
      height: {{ block.settings.thickness }}px;
       background-color: {{ block.settings.color }};
      }

    {% when 'delivery_timeline' %}
      .delivery-timeline-container {
          --tl-accent: {{ block.settings.tl_accent }};
          --tl-accent-light: {{ block.settings.tl_accent_light }};
          --tl-border: {{ block.settings.tl_border }};
          --tl-bg: {{ block.settings.tl_bg }};
          --tl-text: {{ block.settings.tl_text }};
          --tl-muted: {{ block.settings.tl_muted }};
          --tl-pending-bg: {{ block.settings.tl_pending_bg }};
          --tl-pending-color: {{ block.settings.tl_pending_color }};

          background: var(--tl-bg);
          max-width: 100%;
          border: 1px solid var(--tl-border);
          padding: 20px;
          width: 760px;
          margin-bottom: 20px;
        }

        @media(max-width: 400px){
          .delivery-timeline-container{
                padding: 10px;
          }
        }

      {% endcase %}
      {% endfor %}

      @media screen and (min-width: 992px) {
        .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.padding_top }}px;
          padding-bottom: {{ section.settings.padding_bottom }}px;
        }
      }
  {% endstyle %}

  <div class="{{ section.settings.select_contain }} main-product-inner overflow-x product--{{ section.settings.gallery_layout }}">
    <product-info
      id="MainProduct-{{ section.id }}"
      class="gradient color-{{ section.settings.color_scheme }}"
      data-section="{{ section.id }}"
      data-product-id="{{ product.id }}"
      data-update-url="true"
      data-url="{{ product.url }}"
    >
      <div class="main-product">
        <div class="product-gallery-slider">
          {% render 'product-media-gallery',
            gallery_layout: section.settings.gallery_layout,
            enable_fancybox: section.settings.enable_fancybox
          %}
        </div>
        <div class="product-summary">
          <div class="product-summary-inner">
            {%- assign product_form_id = 'product-form-' | append: section.id -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '@app' -%}
                  {% render block %}
                {%- when 'information' -%}
                  <div>
                    <div class="product-info-inner" {{ block.shopify_attributes }}>
                      {% if block.settings.show_tags and product.tags != blank %}
                        <div class="product-infor">
                          <span class="bold">{{ 'products.product.tags' | t }} :</span>
                          <span>{{ product.tags | join: ', ' }}</span>
                        </div>
                      {% endif %}

                      {% if block.settings.show_type and product.type != blank %}
                        <div class="product-infor">
                          <span class="bold">{{ 'products.product.type' | t }} :</span>
                          <span>{{ product.type }}</span>
                        </div>
                      {% endif %}
                      {% assign current_variant = product.selected_or_first_available_variant %}

                      {% if block.settings.show_sku and current_variant.sku != blank %}
                        <div class="product-infor">
                          <span class="bold">{{ 'products.product.sku' | t }} :</span>
                          <span>{{ current_variant.sku }}</span>
                        </div>
                      {% endif %}

                      {% if block.settings.show_barcode and current_variant.barcode != blank %}
                        <div class="product-infor">
                          <span class="bold">{{ 'products.product.barcode' | t }} :</span>
                          <span>{{ current_variant.barcode }}</span>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {% when 'Product_top' %}
                  {% if block.settings.show_vendor and product.vendor != blank %}
                    <div class="product-infor">
                      <span class="bold">{{ 'products.product.vendor' | t }} :</span>
                      <a
                        href="{{ routes.collections_url }}/vendors?q={{ product.vendor | url_encode }}"
                        class="link"
                      >
                        <span>{{ product.vendor }}</span>
                      </a>
                    </div>
                  {% endif %}

                  {% if block.settings.show_collections and product.collections != empty %}
                    <div class="product-infor">
                      <span class="bold">{{ 'products.product.collections' | t }} :</span>
                      {% for collection in product.collections limit: 1 %}
                        <a href="{{ collection.url }}" class="link">
                          <span>{{ collection.title }}</span>
                        </a>
                      {% endfor %}
                    </div>
                  {% endif %}

                {%- when 'title' -%}
                  <div class="product__title {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                    {{ product.title | escape }}
                  </div>

                {%- when 'price' -%}
                  <div
                    id="price-{{ section.id }}"
                    role="status"
                    {{ block.shopify_attributes }}
                    data-section="{{ section.id }}"
                  >
                    {% render 'price', product: product, use_variant: true, show_badges: true %}
                  </div>

                  {% if product.available %}
                    <div class="shop-pay-installments">
                      {{ product | payment_terms }}
                    </div>
                  {% endif %}

                  {%- if product.quantity_price_breaks_configured? -%}
                    <div class="volume-pricing-note" id="Volume-Note-{{ section.id }}">
                      <span>{{ 'products.product.volume_pricing.note' | t }}</span>
                    </div>
                  {%- endif -%}
                  {%- if cart.taxes_included or cart.duties_included or shop.shipping_policy.body != blank -%}
                    <div class="product__tax caption rte">
                      {%- if cart.duties_included and cart.taxes_included -%}
                        {{ 'products.product.duties_and_taxes_included' | t }}
                      {%- elsif cart.taxes_included -%}
                        {{ 'products.product.taxes_included' | t }}
                      {%- elsif cart.duties_included -%}
                        {{ 'products.product.duties_included' | t }}
                      {%- endif -%}
                      {%- if shop.shipping_policy.body != blank -%}
                        {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  <div {{ block.shopify_attributes }}>
                    {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                    {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                      {{ form | payment_terms }}
                    {%- endform -%}
                  </div>

                {%- when 'description' -%}
                  {%- if product.description != blank -%}
                    <div class="product__description-wrapper rte" {{ block.shopify_attributes }}>
                      <span class="short-desc body-text-color product__description quick-add-hidden">
                        {{ product.description | strip_html | truncate: 200 }}
                        <a href="javascript:void(0)" class="more-link" onclick="toggleDesc(this)">
                          {{- 'products.product.more' | t -}}
                        </a>
                      </span>

                      <span class="full-desc product__description quick-add-hidden" style="display:none;">
                        {{ product.description }}
                        <a href="javascript:void(0)" class="less-link" onclick="toggleDesc(this)">
                          {{ 'products.product.less' | t -}}
                        </a>
                      </span>
                    </div>
                  {%- endif -%}

                {%- when 'countdown_timer' -%}
                  {% if block.settings.enable_countdown %}
                    {% assign countdown_date = product.metafields.custom.countdown_end %}

                    {% if countdown_date != blank %}
                      <div
                        class="sale-countdown countdown-timer sale-countdown-{{ block.id }}"
                        data-end-date="{{ countdown_date | date: "%Y-%m-%dT%H:%M:%S" }}"
                      >
                        <p class="sale-text">
                          {{ 'products.product.countdown.default_text' | t }}
                        </p>

                        <div class="countdown">
                          <span
                            ><b class="days">00</b>
                            <span class="mobile-text">{{ 'products.product.countdown.days' | t }}</span></span
                          >:
                          <span
                            ><b class="hours">00</b>
                            <span class="mobile-text">{{ 'products.product.countdown.hrs' | t }}</span></span
                          >:
                          <span
                            ><b class="minutes">00</b>
                            <span class="mobile-text">{{ 'products.product.countdown.min' | t }}</span></span
                          >:
                          <span
                            ><b class="seconds">00</b>
                            <span class="mobile-text">{{ 'products.product.countdown.sec' | t }}</span></span
                          >
                        </div>
                      </div>
                    {% endif %}
                  {% endif %}

                {%- when 'sku' -%}
                  {% if product.selected_or_first_available_variant.sku != blank %}
                    <p
                      class="product__sku{% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                      id="Sku-{{ section.id }}"
                      role="status"
                      {{ block.shopify_attributes }}
                    >
                      <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span>
                      {{- product.selected_or_first_available_variant.sku -}}
                    </p>
                  {% endif %}

                {% when 'divider' %}
                  {% assign show_divider = false %}

                  {% assign prev_index = forloop.index0 | minus: 1 %}
                  {% assign prev_block = section.blocks[prev_index] %}

                  {% if prev_block %}
                    {% case prev_block.type %}
                      {% when 'title',
                        'price',
                        'description',
                        'custom_liquid',
                        'secure_payment',
                        'feature_icons',
                        'Product_top',
                        'buy_buttons'
                      %}
                        {% assign show_divider = true %}

                      {% when 'variant_picker' %}
                        {% unless product.has_only_default_variant %}
                          {% assign show_divider = true %}
                        {% endunless %}

                      {% when 'sku' %}
                        {% if product.selected_or_first_available_variant.sku != blank %}
                          {% assign show_divider = true %}
                        {% endif %}

                      {% when 'inventory' %}
                        {% if product.selected_or_first_available_variant.inventory_management == 'shopify' %}
                          {% assign show_divider = true %}
                        {% endif %}
                    {% endcase %}
                  {% endif %}

                  {% if show_divider %}
                    <div
                      class="custom-divider-wrapper divider--{{ block.id }} {% if block.settings.desktop_only %}desktop-only{% endif %}"
                      {{ block.shopify_attributes }}
                    >
                      <span class="custom-divider-line"></span>
                    </div>
                  {% endif %}

                {%- when 'inventory' -%}
                  {%- liquid
                    assign inv_variant = product.selected_or_first_available_variant
                    assign inv_qty = inv_variant.inventory_quantity
                    assign inv_status = ''
                    if inv_variant.inventory_management == 'shopify'
                      if inv_qty > 0
                        if inv_qty <= block.settings.inventory_threshold
                          assign inv_status = 'inventory--low-stock'
                        else
                          assign inv_status = 'inventory--in-stock'
                        endif
                      else
                        if inv_variant.inventory_policy == 'continue'
                          assign inv_status = 'inventory--in-stock'
                        else
                          assign inv_status = 'inventory--out-of-stock'
                        endif
                      endif
                    endif
                  -%}
                  <p
                    class="product__inventory doken-wrap {{ inv_status }} {% if inv_variant.inventory_management != 'shopify' %}visibility-hidden{% endif %}"
                    {{ block.shopify_attributes }}
                    id="Inventory-{{ section.id }}"
                    role="status"
                    data-threshold="{{ block.settings.inventory_threshold }}"
                    data-show-count="{{ block.settings.show_inventory_quantity }}"
                  >
                    {%- if inv_variant.inventory_management == 'shopify' -%}
                      {%- if inv_qty > 0 -%}
                        {%- if inv_qty <= block.settings.inventory_threshold -%}
                          <span class="svg-wrapper">
                            {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                          </span>
                          {%- if block.settings.show_inventory_quantity -%}
                            {{- 'products.product.inventory_low_stock_show_count' | t: quantity: inv_qty -}}
                          {%- else -%}
                            {{- 'products.product.inventory_low_stock' | t -}}
                          {%- endif -%}
                        {%- else -%}
                          <span class="svg-wrapper">
                            {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                          </span>
                          {%- if block.settings.show_inventory_quantity -%}
                            {{- 'products.product.inventory_in_stock_show_count' | t: quantity: inv_qty -}}
                          {%- else -%}
                            {{- 'products.product.inventory_in_stock' | t -}}
                          {%- endif -%}
                        {%- endif -%}
                      {%- else -%}
                        {%- if inv_variant.inventory_policy == 'continue' -%}
                          <span class="svg-wrapper">
                            {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                          </span>
                          {{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}
                        {%- else -%}
                          <span class="svg-wrapper">
                            {{- 'icon-inventory-status.svg' | inline_asset_content -}}
                          </span>
                          {{- 'products.product.inventory_out_of_stock' | t -}}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endif -%}
                  </p>

                {% when 'rating' %}
                  <div class="rating" role="img" aria-label="{{ rating_value }} out of {{ rating_max }} stars">
                    <span
                      class="rating-star"
                      style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max | default: 5 }}; --rating-decimal: {{ rating_decimal }};"
                    ></span>
                    <span class="rating-count">({{ product.metafields.reviews.rating_count }})</span>
                  </div>

                {%- when 'share' -%}
                  {% liquid
                    assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin
                    render 'share-button', block: block, share_link: share_url
                  %}

                {%- when 'custom_liquid' -%}
                  {{ block.settings.custom_liquid }}

                {%- when 'collapsible_tab' -%}
                  {% if block.settings.heading != blank %}
                    <div class="product__accordion accordion quick-add-hidden" {{ block.shopify_attributes }}>
                      <details id="Details-{{ block.id }}-{{ section.id }}" class="product-accordion">
                        <summary class="accordion-summary">
                          <div class="summary__title">
                            {% render 'icon-accordion', icon: block.settings.icon %}
                            <div class="accordion__title inline-richtext {{ block.settings.heading_size }}">
                              {{ block.settings.heading | default: block.settings.page.title | escape }}
                            </div>
                          </div>
                          {{- 'icon-caret.svg' | inline_asset_content -}}
                        </summary>
                        <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                          {{ block.settings.content }}
                          {{ block.settings.page.content }}
                        </div>
                      </details>
                    </div>
                  {% endif %}
                {%- when 'bundle_products' -%}
                  {%- unless product.gift_card? -%}
                    <div class="bundle-section" id="bundle-section-{{ block.id }}">
                      {%- if block.settings.show_offer_banner -%}
                        <div class="bundle-banner">
                          <h3 class="bundle-banner__text">
                            {{- block.settings.offer_text -}}
                            {{- block.settings.discount_percentage }}% OFF
                          </h3>
                        </div>
                      {%- endif -%}

                      <div class="bundle-products" id="bundle-products-{{ block.id }}">
                        {%- for i in (1..3) -%}
                          {%- assign product_setting = 'product_' | append: i -%}
                          {%- assign compare_price_setting = 'compare_price_' | append: i -%}
                          {%- assign product_obj = block.settings[product_setting] -%}

                          {%- if product_obj != blank -%}
                            {%- assign current_variant = product_obj.selected_or_first_available_variant -%}
                            <div class="bundle-item" data-bundle-item data-product-id="{{ product_obj.id }}">
                              <div class="bundle-item__checkbox-wrap">
                                <input
                                  type="checkbox"
                                  class="bundle-item__checkbox"
                                  id="bundle-check-{{ block.id }}-{{ i }}"
                                  data-product-index="{{ i }}"
                                  checked
                                >
                                <label
                                  class="bundle-item__checkbox-label"
                                  for="bundle-check-{{ block.id }}-{{ i }}"
                                ></label>
                              </div>

                              <div class="bundle-item__image-wrap">
                                {%- if product_obj.featured_image -%}
                                  <img
                                    src="{{ product_obj.featured_image | image_url: width: 120 }}"
                                    srcset="
                                      {{ product_obj.featured_image | image_url: width: 120 }} 1x,
                                      {{ product_obj.featured_image | image_url: width: 240 }} 2x
                                    "
                                    alt="{{ product_obj.featured_image.alt | escape }}"
                                    width="120"
                                    height="{{ 120 | divided_by: product_obj.featured_image.aspect_ratio | ceil }}"
                                    loading="lazy"
                                    class="bundle-item__image"
                                  >
                                {%- else -%}
                                  <div class="bundle-item__image bundle-item__image--placeholder">
                                    {{ 'product-1' | placeholder_svg_tag }}
                                  </div>
                                {%- endif -%}
                              </div>

                              <div class="bundle-item__details">
                                <h6 class="bundle-item__title">
                                  <a href="{{ product_obj.url }}" class="h6">{{ product_obj.title }}</a>
                                </h6>

                                <div class="bundle-item__price-row price">
                                  <span class="bundle-item__price bundle-item__price--current">
                                    {{ current_variant.price | money }}
                                  </span>
                                  {%- if block.settings[compare_price_setting] != blank -%}
                                    <span class="bundle-item__price bundle-item__price--compare">
                                      {{ block.settings[compare_price_setting] | money }}
                                    </span>
                                  {%- elsif current_variant.compare_at_price > current_variant.price -%}
                                    <span class="bundle-item__price bundle-item__price--compare">
                                      {{ current_variant.compare_at_price | money }}
                                    </span>
                                  {%- endif -%}
                                </div>

                                {%- unless product_obj.has_only_default_variant -%}
                                  <div class="bundle-item__options">
                                    {%- for option in product_obj.options_with_values -%}
                                      <div class="bundle-item__option-group">
                                        <label
                                          class="bundle-item__option-label"
                                          for="option-{{ block.id }}-{{ i }}-{{ forloop.index }}"
                                        >
                                          {{ option.name }}:
                                        </label>
                                        <div class="bundle-item__select-wrap">
                                          <select
                                            class="bundle-item__select"
                                            id="option-{{ block.id }}-{{ i }}-{{ forloop.index }}"
                                            data-option-index="{{ forloop.index0 }}"
                                            data-product-index="{{ i }}"
                                          >
                                            {%- for value in option.values -%}
                                              <option
                                                value="{{ value | escape }}"
                                                {%- if option.selected_value == value -%}
                                                  selected
                                                {%- endif -%}
                                              >
                                                {{ value }}
                                              </option>
                                            {%- endfor -%}
                                          </select>
                                          <svg
                                            class="bundle-item__select-arrow"
                                            width="10"
                                            height="6"
                                            viewBox="0 0 10 6"
                                            fill="none"
                                          >
                                            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                          </svg>
                                        </div>
                                      </div>
                                    {%- endfor -%}
                                  </div>
                                {%- endunless -%}

                                <div class="bundle-item__qty-row cart-item__quantity">
                                  <button
                                    type="button"
                                    class="bundle-item__qty-btn bundle-item__qty-btn--minus minus qty-btn"
                                    data-qty-minus
                                    aria-label="Decrease quantity"
                                  >
                                    <span class="svg-wrapper">
                                      {{- 'icon-minus.svg' | inline_asset_content -}}
                                    </span>
                                  </button>
                                  <input
                                    type="number"
                                    class="bundle-item__qty-input cart-qty-input"
                                    value="1"
                                    min="1"
                                    max="99"
                                    data-qty-input
                                    aria-label="Quantity"
                                  >
                                  <button
                                    type="button"
                                    class="bundle-item__qty-btn bundle-item__qty-btn--plus qty-btn plus"
                                    data-qty-plus
                                    aria-label="Increase quantity"
                                  >
                                    <span class="svg-wrapper">
                                      {{- 'icon-plus.svg' | inline_asset_content -}}
                                    </span>
                                  </button>
                                </div>
                              </div>
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>

                      <div class="bundle-footer">
                        <div class="bundle-footer__summary">
                          <p class="bundle-footer__label body-text-color">
                            {{- block.settings.total_label | default: 'Bundle Total:' -}}
                          </p>
                          <span class="bundle-footer__total flex-div price" id="bundle-total-{{ block.id }}">
                            <span
                              class="bundle-total__original"
                            ></span>
                            <span class="bundle-total__final body-text-color"></span>
                          </span>
                        </div>

                        {% if block.settings.button_text != blank %}
                          <div>
                            <button
                              type="button"
                              class="
                                bundle-footer__btn {% if block.settings.button_style == 'btn-underline_hover' %}
                                  btn-underline_hover
                                {% else %}
                                  button {% if settings.enable_btn_hover_effect %} custom-submit-button {% endif %} {{ block.settings.button_style }}
                                {% endif %}
                              "
                              id="bundle-add-btn-{{ block.id }}"
                              data-bundle-add
                            >
                              {% if block.settings.button_style == 'btn-underline_hover' %}
                                {{ block.settings.button_text }}
                              {% else %}
                                <div class="hover-hide">
                                  {{ block.settings.button_text }}
                                </div>

                                <div class="hover-show">
                                  {% assign letters = block.settings.button_text | split: '' %}
                                  {% for letter in letters %}
                                    {% if letter == ' ' %}
                                      <span class="letter-space" style="--i:{{ forloop.index }}">&nbsp;</span>
                                    {% else %}
                                      <span style="--i:{{ forloop.index }}">{{ letter }}</span>
                                    {% endif %}
                                  {% endfor %}
                                </div>
                              {% endif %}
                            </button>
                          </div>
                        {% endif %}
                      </div>
                    </div>

                    <script>
                      window.BundleConfig = window.BundleConfig || [];
                      window.BundleConfig.push({
                        sectionId:       '{{ block.id }}',
                        discountPct:     {{ block.settings.discount_percentage | default: 20 }},
                        offerText:       {{ block.settings.offer_text | json }},
                        btnText:         {{ block.settings.button_text | json }},
                        productData: {
                          {%- for i in (1..3) -%}
                            {%- assign product_setting = 'product_' | append: i -%}
                            {%- assign product_obj = block.settings[product_setting] -%}
