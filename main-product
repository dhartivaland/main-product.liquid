                          </li>
                        {%- endfor -%}
                      </ul>
                    </div>
                  </div>

                {% when 'feature_icons' %}
                  {% render 'feature-icons', block: block %}

                {%- when 'popup' -%}
                  {%- unless product.gift_card? -%}
