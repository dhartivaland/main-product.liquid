                    <script>
                      (function () {
                        var CONFIG = {
                          shipDaysMin: 0,
                          shipDaysMax: 1,
                          delivDaysMin: 2,
                          delivDaysMax: 1,
                          skipWeekends: true,
                          cutoffHour: 15,

                          holidays: [],
                        };

                        /* ── HELPERS ──────────────────────────────────────────── */
                        var MONTHS_SHORT = [
                          'Jan',
                          'Feb',
                          'Mar',
                          'Apr',
                          'May',
                          'Jun',
                          'Jul',
                          'Aug',
                          'Sep',
                          'Oct',
                          'Nov',
                          'Dec',
                        ];
                        var MONTHS_FULL = [
                          'January',
                          'February',
                          'March',
                          'April',
                          'May',
                          'June',
                          'July',
                          'August',
                          'September',
                          'October',
                          'November',
                          'December',
                        ];

                        function ord(d) {
                          var s = ['th', 'st', 'nd', 'rd'],
                            v = d % 100;
                          return d + (s[(v - 20) % 10] || s[v] || s[0]);
                        }

                        function fmt(date) {
                          return ord(date.getDate()) + ' ' + MONTHS_SHORT[date.getMonth()];
                        }

                        function fmtFull(date) {
                          return MONTHS_FULL[date.getMonth()] + ' ' + ord(date.getDate());
                        }

                        function fmtRange(a, b) {
                          if (a.getMonth() === b.getMonth())
                            return ord(a.getDate()) + '–' + ord(b.getDate()) + ' ' + MONTHS_SHORT[a.getMonth()];
                          return (
                            ord(a.getDate()) +
                            ' ' +
                            MONTHS_SHORT[a.getMonth()] +
                            ' – ' +
                            ord(b.getDate()) +
                            ' ' +
                            MONTHS_SHORT[b.getMonth()]
                          );
                        }

                        function toYMD(date) {
                          return (
                            date.getFullYear() +
                            '-' +
                            ('0' + (date.getMonth() + 1)).slice(-2) +
                            '-' +
                            ('0' + date.getDate()).slice(-2)
                          );
                        }

                        function isHoliday(date) {
                          return CONFIG.holidays.indexOf(toYMD(date)) !== -1;
                        }

                        function isNonWorkingDay(date) {
                          var day = date.getDay();
                          return (CONFIG.skipWeekends && (day === 0 || day === 6)) || isHoliday(date);
                        }

                        function nextWorkingDay(date) {
                          var d = new Date(date);
                          while (isNonWorkingDay(d)) d.setDate(d.getDate() + 1);
                          return d;
                        }

                        function addWorkingDays(date, n) {
                          var d = new Date(date),
                            count = 0;
                          while (count < n) {
                            d.setDate(d.getDate() + 1);
                            if (!isNonWorkingDay(d)) count++;
                          }
                          return d;
                        }

                        function addDays(date, n) {
                          var d = new Date(date);
                          d.setDate(d.getDate() + n);
                          return d;
                        }

                        /* ── MAIN ─────────────────────────────────────────────── */
                        function init() {
                          var sectionId = '{{ block.id }}';
                          var now = new Date();
                          var hour = now.getHours();

                          /* Base order date — shift to next working day if after cutoff */
                          var base = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                          if (hour >= CONFIG.cutoffHour) base = addWorkingDays(base, 1);
                          var orderDate = nextWorkingDay(base);

                          /* Ship window */
                          var shipStart = nextWorkingDay(addDays(orderDate, CONFIG.shipDaysMin));
                          var shipEnd = nextWorkingDay(addDays(shipStart, CONFIG.shipDaysMax));

                          /* Delivery window */
                          var delivStart = addWorkingDays(shipEnd, CONFIG.delivDaysMin);
                          var delivEnd = nextWorkingDay(addDays(delivStart, CONFIG.delivDaysMax));

                          /* ── Update DOM ── */
                          var el = function (id) {
                            return document.getElementById(id + '-' + sectionId);
                          };

                          /* Badge dates */
                          el('tl-badge-1').textContent = fmt(new Date());
                          el('tl-badge-2').textContent = fmtRange(shipStart, shipEnd);
                          el('tl-badge-3').textContent = fmtRange(delivStart, delivEnd);

                          /* Step 3 badge style (pending → active colour once dates loaded) */
                          var badge3 = el('tl-badge-3');
                          badge3.classList.remove('pending-badge');

                          /* Info bar */
                          var infoEl = el('tl-info');
                          var afterCutoff = hour >= CONFIG.cutoffHour;
                          if (afterCutoff) {
                            infoEl.innerHTML =
                              'Order placed after ' +
                              CONFIG.cutoffHour +
                              ':00. Shipping starts <strong>' +
                              fmt(shipStart) +
                              '</strong>. Expected delivery by <strong>' +
                              fmtFull(delivEnd) +
                              '</strong>.';
                          } else {
                            infoEl.innerHTML =
                              'Order confirmed! Estimated delivery between <strong>' +
                              fmtFull(delivStart) +
                              '</strong> and <strong>' +
                              fmtFull(delivEnd) +
                              '</strong>.';
                          }

                          /* Animate progress line */
                          setTimeout(function () {
                            var fill = document.getElementById('tl-fill-' + sectionId);
                            if (fill) fill.style.width = '50%';
                          }, 150);
                        }

                        if (document.readyState === 'loading') {
                          document.addEventListener('DOMContentLoaded', init);
                        } else {
                          init();
                        }
                      })();
                    </script>
                  {%- endunless -%}

                {%- when 'variant_picker' -%}
                  {% render 'product-variant-picker',
                    product: product,
                    block: block,
                    product_form_id: product_form_id
                  %}

                {%- when 'buy_buttons' -%}
